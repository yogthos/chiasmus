{
  "name": "chiasmus",
  "version": "0.1.3",
  "type": "module",
  "description": "Neurosymbolic verification engine - MCP server for formal reasoning with Z3 and Tau Prolog",
  "main": "dist/mcp-server.js",
  "types": "dist/mcp-server.d.ts",
  "bin": {
    "chiasmus": "dist/mcp-server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/mcp-server.d.ts",
      "default": "./dist/mcp-server.js"
    },
    "./solvers": {
      "types": "./dist/solvers/types.d.ts",
      "default": "./dist/solvers/types.js"
    },
    "./skills": {
      "types": "./dist/skills/types.d.ts",
      "default": "./dist/skills/types.js"
    },
    "./formalize": {
      "types": "./dist/formalize/engine.d.ts",
      "default": "./dist/formalize/engine.js"
    },
    "./llm": {
      "types": "./dist/llm/types.d.ts",
      "default": "./dist/llm/types.js"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "mcp": "tsx src/mcp-server.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "z3",
    "prolog",
    "formal-verification",
    "neurosymbolic",
    "smt",
    "solver",
    "model-context-protocol",
    "claude",
    "llm"
  ],
  "license": "Apache-2.0",
  "author": "yogthos",
  "repository": {
    "type": "git",
    "url": "https://github.com/yogthos/chiasmus.git"
  },
  "homepage": "https://github.com/yogthos/chiasmus#readme",
  "bugs": {
    "url": "https://github.com/yogthos/chiasmus/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.8.0",
    "tau-prolog": "^0.3.4",
    "tree-sitter": "^0.21.1",
    "tree-sitter-javascript": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "z3-solver": "^4.16.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
